# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/resume-helper?retryWrites=true&w=majority

# JWT secret - use a long random string in production
JWT_SECRET=replace_this_with_a_long_random_secret_string

# Ollama local server settings (no API key needed — runs free, locally)
# Make sure "ollama serve" is running and the model below has been pulled:
#   ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Server port
PORT=5000

# Comma-separated list of allowed frontend origins (for CORS)
CLIENT_ORIGIN=http://localhost:5173
